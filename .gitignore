pipeline/**/*.pt
pipeline/**/*.pth
pipeline/**/checkpoint-*/

# Viewer build artifacts
viewer/node_modules/
viewer/dist/
viewer/.vite/

# Compiled macOS app (source is in menubar/Sources/)
menubar/*.app

# Generated reports
pipeline/REPORT.md
